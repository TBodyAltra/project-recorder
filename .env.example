# ============================================
# Provider preset: openai / minimax / deepseek / siliconflow / zhipuai / custom
PROVIDER=minimax

# ============================================
# Vision API (for screenshot analysis)
VISION_API_KEY=your_vision_api_key_here
VISION_BASE_URL=https://api.minimax.chat/v1
VISION_MODEL=MiniMax-VL-01

# ============================================
# LLM API (for generating project brief)
LLM_API_KEY=your_llm_api_key_here
LLM_BASE_URL=https://api.minimax.chat/v1
LLM_MODEL=MiniMax-Text-01

# ============================================
# Whisper (local, no API needed)
WHISPER_MODEL=base
